	CLEANMAC_TEST_MODE=1 CLEANMAC_TEST_NO_AUTH=1 PYTHONDONTWRITEBYTECODE=1 PYTEST_ADDOPTS="-p no:cacheprovider" "$$tmpdir/venv/bin/python" -m pytest $(PYTEST_SAFE_TARGETS) -q

