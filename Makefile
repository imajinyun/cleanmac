pytest-no-unittest-regression-smoke:
	$(PYTHON) -c 'from pathlib import Path; text=Path("tests/test_mcp_server.py").read_text(encoding="utf-8"); forbidden=("import unittest", "unittest.TestCase", "unittest.main", "self.assert"); [(_ for _ in ()).throw(AssertionError(f"tests/test_mcp_server.py still contains {token}")) for token in forbidden if token in text]; assert "def test_" in text; assert "from unittest.mock import patch" in text; makefile=Path("Makefile").read_text(encoding="utf-8"); assert "PYTEST_AI_HOST_TARGETS := " in makefile and "tests/test_mcp_server.py" in makefile; assert "pytest-ai-host-smoke" in makefile; print("pytest-no-unittest-regression-smoke passed")'

pytest-governance-smoke: pytest-no-unittest-regression-smoke
	$(PYTHON) -c 'from pathlib import Path; text=Path("Makefile").read_text(encoding="utf-8"); expected=["tests/test_release_readiness.py", "tests/test_release_orchestration.py", "tests/test_release_artifacts.py", "tests/test_path_safety.py", "tests/test_trash_mode.py", "tests/test_delete_ops.py", "tests/test_security_scan.py"]; expected_robustness=["tests/test_ai_versioning.py", "tests/test_mcp_protocol.py", "tests/test_ai_concurrency.py", "tests/test_ai_policy.py", "tests/test_ai_host_integration.py", "tests/test_ai_contract.py", "tests/test_ai_errors.py", "tests/test_ai_idempotency.py", "tests/test_ai_runbook.py", "tests/test_ai_host_policy.py", "tests/test_ai_self_test.py", "tests/test_ai_decision_matrix.py", "tests/test_ai_governance.py", "tests/test_ai_host_evidence.py", "tests/test_ai_readiness.py", "tests/test_ai_trace_persistence.py"]; line=next(row for row in text.splitlines() if row.startswith("PYTEST_SAFE_TARGETS :=")); targets=line.split(":=", 1)[1].split(); robustness_line=next(row for row in text.splitlines() if row.startswith("PYTEST_AI_ROBUSTNESS_TARGETS :=")); robustness_targets=robustness_line.split(":=", 1)[1].split(); old_all="pytest test_cleanmac.py " + "tests -q"; old_broad="pytest " + "tests -q"; old_robustness="python -m unittest " + "tests.test_ai_versioning"; old_ai_host_policy="python -m unittest " + "tests.test_ai_host_policy"; old_ai_runbook="python -m unittest " + "tests.test_ai_runbook"; old_ai_self_test="python -m unittest " + "tests.test_ai_self_test"; old_ai_decision_matrix="python -m unittest " + "tests.test_ai_decision_matrix"; old_ai_governance="python -m unittest " + "tests.test_ai_governance"; old_ai_host_evidence="python -m unittest " + "tests.test_ai_host_evidence"; old_ai_readiness="python -m unittest " + "tests.test_ai_readiness"; assert targets == expected, targets; assert robustness_targets == expected_robustness, robustness_targets; [(_ for _ in ()).throw(AssertionError(f"missing pytest safe target: {target}")) for target in targets if not Path(target).is_file()]; [(_ for _ in ()).throw(AssertionError(f"missing pytest AI robustness target: {target}")) for target in robustness_targets if "::" not in target and not Path(target).is_file()]; assert "pytest $$(PYTEST_SAFE_TARGETS) -q" in text; assert "pytest $$(PYTEST_AI_ROBUSTNESS_TARGETS) -q" in text; assert old_all not in text; assert old_broad not in text; assert old_robustness not in text; assert old_ai_host_policy not in text; assert old_ai_runbook not in text; assert old_ai_self_test not in text; assert old_ai_decision_matrix not in text; assert old_ai_governance not in text; assert old_ai_host_evidence not in text; assert old_ai_readiness not in text; assert "pytest-governance-smoke" in next(row for row in text.splitlines() if row.startswith("release-check:")); print("pytest-governance-smoke passed")'

build-check:
	tmpdir=$$(mktemp -d); \
	trap 'rm -rf "$$tmpdir"; $(MAKE) clean-test-artifacts >/dev/null' EXIT; \
	$(PYTHON) -m build --wheel --sdist --outdir "$$tmpdir/dist"; \
	$(PYTHON) -m twine check "$$tmpdir"/dist/*

package-smoke:
